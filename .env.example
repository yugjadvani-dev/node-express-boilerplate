# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
APP_NAME="Node Express TS PG Boilerplate"

# ============================================================
# DATABASE - PostgreSQL
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=api_boilerplate
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# For node-pg-migrate
DATABASE_URL=postgres://postgres:your_strong_password_here@localhost:5432/api_boilerplate

# ============================================================
# JWT AUTHENTICATION
# ============================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_char_hex_string
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=60

# ============================================================
# EMAIL (Nodemailer)
# ============================================================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@yourapp.com

# ============================================================
# SECURITY
# ============================================================
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Comma-separated list of trusted IPs (optional)
TRUSTED_IPS=

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=debug

# ============================================================
# BCRYPT
# ============================================================
BCRYPT_ROUNDS=12
