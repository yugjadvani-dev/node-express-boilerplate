# Test environment — safe to commit (no real secrets)
NODE_ENV=test
PORT=3001
API_PREFIX=/api/v1
APP_NAME=API Boilerplate Test

DB_HOST=localhost
DB_PORT=5432
DB_NAME=api_test
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

DATABASE_URL=postgres://postgres:postgres@localhost:5432/api_test

JWT_ACCESS_SECRET=test_access_secret_that_is_at_least_32_chars_long
JWT_REFRESH_SECRET=test_refresh_secret_that_is_at_least_32_chars_long
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=60

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=test@example.com

CORS_ORIGIN=http://localhost:3001
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

LOG_LEVEL=silent
BCRYPT_ROUNDS=4
